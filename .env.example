# Copy to .env and fill values. IMAP_ACCOUNTS must be valid JSON.
IMAP_ACCOUNTS=[
  {
    "label": "example",
    "server": "mail.example.com:993",
    "user": "user@example.com",
    "password": "yourpassword",
    "folder": "INBOX"
  }
]

# OpenAI API key for phishing detection (required)
AI_API_KEY="your_openai_api_key"

# Optional: scan existing messages on startup (max 10) and then remember latest UID
IMAP_SCAN_ON_START=false
IMAP_SCAN_ON_START_MAX=10
